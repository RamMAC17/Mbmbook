# MBM Book Configuration
# Copy to .env and customize

# Application
MBM_DEBUG=true
MBM_HOST=0.0.0.0
MBM_PORT=9999
MBM_HOST_IP=0.0.0.0
MBM_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Database
MBM_DATABASE_URL=sqlite+aiosqlite:///data/mbmbook.db

# Cluster
MBM_RAY_HEAD_ADDRESS=auto
MBM_CLUSTER_NAME=mbmbook-lab

# Docker
MBM_DOCKER_NETWORK=mbmbook-net
MBM_KERNEL_IMAGE_PREFIX=mbmbook-kernel
MBM_KERNEL_TIMEOUT=3600
MBM_MAX_KERNELS_PER_NODE=10

# Resource Limits (per kernel)
MBM_DEFAULT_CPU_LIMIT=2.0
MBM_DEFAULT_MEMORY_LIMIT=4g
MBM_DEFAULT_GPU_LIMIT=0
